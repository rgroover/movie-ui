{
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff"
  },
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  }
}
